{
  // Type-checking only (noEmit) for a plain-JS codebase via `checkJs` + JSDoc.
  // Vite builds the code with esbuild; this config exists purely for the
  // `npm run typecheck` gate and editor IntelliSense.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    // Pragmatic strictness for incremental JS typing: still catches unknown
    // properties, wrong argument counts and type mismatches, without drowning
    // in implicit-any / DOM-null noise. Tighten as JSDoc coverage grows.
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/js/**/*.js"],
  // The large view-controllers are DOM-glue and typed incrementally in a
  // later pass; the reusable logic layer (queries, demo DB, i18n, …) is checked.
  "exclude": [
    "src/js/admin.js",
    "src/js/teacher.js",
    "src/js/main.js",
    "src/js/login.js",
    "node_modules",
    "dist"
  ]
}
